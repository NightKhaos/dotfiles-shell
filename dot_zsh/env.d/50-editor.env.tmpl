# Default editor — prefer nvim when installed, fall back to vim.
#
# Decided at `chezmoi apply` time (template), not shell-init time, so the
# per-shell `env.d` source stays a static export with zero startup cost. The
# trade-off: installing/removing nvim after an apply leaves this stale until the
# next `chezmoi apply` — acceptable, since changing your editor toolchain is a
# deliberate act that already warrants a re-apply.
#
# lookPath honours chezmoi's PATH, which includes /snap/bin, so the snap nvim
# at /snap/bin/nvim is correctly detected.
{{ if lookPath "nvim" -}}
export EDITOR=nvim
{{- else -}}
export EDITOR=vim
{{- end }}
