# Make user-local terminfo entries (~/.terminfo) resolvable, in particular
# for snap-confined TUIs.
#
# Snap sandboxes ship only a base terminfo set and cannot read the host
# /usr/share/terminfo, so a snap TUI launched under TERM=alacritty fails with
# "Error opening terminal: alacritty". The sandbox also redirects $HOME to
# ~/snap/<app>/<rev>/, so ncurses' default "$HOME/.terminfo" lookup points at
# the wrong place inside the snap. Setting TERMINFO_DIRS to the *absolute*
# real ~/.terminfo (exported, so it crosses into the sandbox) makes the
# mirrored entries resolvable inside snap confinement.
#
# The companion ~/.terminfo entries are generated by dotfiles-hyprland's
# run_after_terminfo-user-entries.sh (tic from the host's compiled terminfo).
#
# Trailing colon → ncurses appends the compiled system terminfo dirs, so
# host-wide entries (xterm-256color, etc.) continue to resolve normally.
export TERMINFO_DIRS="$HOME/.terminfo:"
