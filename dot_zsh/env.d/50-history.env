# History configuration
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=$HOME/.zsh_history
setopt appendhistory
# Write each command to $HISTFILE as it is entered, rather than batching the
# whole session's history into one append on shell exit. The batched-on-exit
# write is a large, infrequent fsync window; an unclean shutdown mid-flush
# leaves the un-flushed tail zero-filled by ext4 recovery (observed
# 2026-06-04: a 643-byte NUL run mid-file). Incremental append caps the loss
# at the single in-flight command. See specs/future-features.md "atuin".
setopt INC_APPEND_HISTORY
# Lock $HISTFILE with fcntl() during read/write so concurrent shells cannot
# interleave writes and corrupt the file. Also faster than zsh's default
# ad-hoc locking on modern Linux.
setopt HIST_FCNTL_LOCK
setopt HIST_IGNORE_SPACE
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_ALL_DUPS
